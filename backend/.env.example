APP_ENV=development
PROJECT_ROOT=..
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://192.168.1.196:5173"]
VLLM_BASE_URL=http://127.0.0.1:8042/v1
VLLM_API_KEY=dummy
VLLM_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
DGX_VLLM_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
VLLM_MAX_TOKENS=8192
VLLM_TEMPERATURE=0.2
VLLM_NUM_CTX=262144
VLLM_RESERVED_OUTPUT_TOKENS=8192
SPEC_PROMPT_TOKEN_BUDGET=78643
SPEC_PROMPT_MAX_CONTEXT_FRACTION=0.30
VLLM_TIMEOUT_SECONDS=600
APP_DEFAULT_SPEC_SOURCE=project_spec
USB_SPEC_ROOT=/media/peterstroessler/C6B5-FBEC/spec

# On an Apple Silicon Mac without vLLM installed, use Ollama's OpenAI-compatible API instead:
# VLLM_BASE_URL=http://127.0.0.1:11434/v1
# VLLM_MODEL=qwen2.5-coder:3b
# M1_OLLAMA_MODEL=qwen2.5-coder:3b
# VLLM_NUM_CTX=32768
# SPEC_PROMPT_TOKEN_BUDGET=9830
# SPEC_PROMPT_MAX_CONTEXT_FRACTION=0.30
#
# On DGX/Linux with the same USB stick, use:
# APP_DEFAULT_SPEC_SOURCE=usb_untitled_spec
# USB_SPEC_ROOT=/media/$USER/C6B5-FBEC/spec
# VLLM_NUM_CTX=262144
